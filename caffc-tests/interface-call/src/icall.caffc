module main

interface I {
  x() -> str
}

class A implements I {
  x() -> str {
    return "A"
  }
}

class B implements I {
  x() -> str {
    return "B"
  }
}

die(str message) {
  print(message)
  exit(1)
}

checkInstanceOf() {
  I i = new A()

  if not i instanceof A {
    die("i instanceof A failed")
  }

  if not i instanceof I {
    die("i instanceof I failed")
  }

  if not i instanceof obj {
    die("i instanceof obj failed")
  }

  if i instanceof B {
    die("i instanceof B shouldn't be true")
  }
}

main() {
  checkInstanceOf()

  I a = new A()
  I b = new B()

  print(a.x())
  print(b.x())

  a = b

  print(a.x())
  print(b.x())
}
